import sys
from pathlib import Path
from datetime import timedelta

project_root = Path(__file__).resolve().parent.parent
if str(project_root) not in sys.path:
    sys.path.insert(0, str(project_root))

from src.layer1_data.csv_parser import load_historical_1m_data
from src.layer2_theory.market_state import MarketTheoryState
from src.layer3_strategy.config_parser import ConfigParser
from src.layer3_strategy.rule_engine import RuleEngine
from src.layer4_execution.data_vault import DataVault
from src.layer4_execution.simulator import BacktestSimulator
from src.layer2_theory.models import LevelType

def run_pinned_strategy():
    candles = load_historical_1m_data(project_root / 'data/historical/NQ_1min.csv')
    latest_time = candles[-1].timestamp
    cutoff_time = latest_time - timedelta(days=28) # covers last 4 weeks
    small_candles = [c for c in candles if c.timestamp >= cutoff_time]
    
    print(f"--- Running Pine Script Logic Test over last 4 weeks ---")
    
    theory_state = MarketTheoryState()
    playbook_config = ConfigParser.load_playbook(str(project_root / 'data/playbooks/day_trading_decrypted.json'))
    
    data_vault = DataVault()
    simulator = BacktestSimulator(vault=data_vault)
    
    trade_logs = []
    
    for candle in small_candles:
        pre_trades = len(simulator.vault.trades)
        simulator.process_candle(candle)
        post_trades = len(simulator.vault.trades)
        
        if post_trades > pre_trades:
            # A trade was concluded!
            t = simulator.vault.trades[-1]
            if hasattr(simulator, '_pending_metadata'):
                trade_logs.append({
                    'trade': t,
                    'meta': simulator._pending_metadata
                })
                delattr(simulator, '_pending_metadata')
                
        theory_state.process_candle(candle)
        
        # Evaluate using standard playbook
        intents = RuleEngine(playbook_config).evaluate(theory_state=theory_state, timestamp=candle.timestamp)
        
        # CLEAR PENDING INTENT IF MODULES REJECTED IT!
        if simulator.active_pos is None and len(intents) == 0:
            simulator.pending_intent = None
            if hasattr(simulator, "_pending_metadata"):
                delattr(simulator, "_pending_metadata")
        
        for intent in intents:
            if simulator.active_pos is None:
                # Check for an active Origin Level (most recent first!)
                active_origin = None
                for ot in theory_state.origin_trackers: # HIGHLANDER RULE: OLDEST FIRST
                    match_direction = (ot.level_data.is_bullish == intent.is_bullish)
                    if ot.is_active and ot.level_data.level_type == LevelType.ORIGIN_LEVEL and match_direction:
                        active_origin = ot
                        break
                        
                # If we have an Origin Level (the intent already means it's a valid Virgin Hold Level)
                if active_origin:
                    # Clear pending if staging new
                    if hasattr(simulator, "_pending_metadata"):
                        delattr(simulator, "_pending_metadata")
                        
                    simulator.stage_order(intent)
                    
                    # Convert float timestamp back or use as is (for display only)
                    import datetime
                    dt_hold = datetime.datetime.fromtimestamp(intent.theory_reference_ts)
                    
                    simulator._pending_metadata = {
                        'hold_formed_at': dt_hold,
                        'origin_formed_at': active_origin.level_data.timestamp,
                        'origin_test_count': active_origin.test_count
                    }
                
    summary = data_vault.generate_summary()
    print(f"\n--- 4-WEEK PERFORMANCE SUMMARY ---")
    print(f"Total Trades: {summary['total_trades']}")
    print(f"Wins: {summary['wins']} / Losses: {summary['losses']} (Win Rate: {summary['win_rate_pct']}%)")
    print(f"Net PnL (Points): {summary['net_pnl_points']:.2f}")
    print(f"Max Drawdown (Points): {summary['max_drawdown_points']:.2f}")
    print(f"---------------------------------\n")

    print(f"\nTotal trades matching exact Pine logic: {len(trade_logs)}\n")
    for idx, log in enumerate(trade_logs[-3:]):
        t = log['trade']
        m = log['meta']
        direction = "LONG" if t.is_bullish else "SHORT"
        result = "WIN" if t.win else "LOSS"
        print(f"==================================================")
        print(f"TRADE {idx+1}: {direction} | Result: {result} ({t.pnl_points:+.2f} pts)")
        print(f"1. INITIALIZATION: Break Level gevormd om: {m['origin_formed_at']}")
        print(f"2. VALIDATIE: Level is getransformeerd naar Origin Level (Tests: {m['origin_test_count']})")
        print(f"3. ENTRY ZONE: Virgin Hold Level gevormd om: {m['hold_formed_at']}")
        print(f"4. EXECUTION: Limit Order gevuld om: {t.entry_time} @ prijs {t.entry_price}")
        print(f"5. RESOLUTION: Trade afgesloten om: {t.exit_time}")
        print(f"==================================================\n")

if __name__ == '__main__':
    run_pinned_strategy()
